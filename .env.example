# Optional model adviser. Leave SMART_HEDGE_MODEL_KIND=heuristic for a free local demo.
SMART_HEDGE_MODEL_KIND=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=

# Optional read-only Alpaca market-data adapter. No trading endpoint is implemented.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
SMART_HEDGE_PROVIDER=synthetic

# Optional FRED macro connector.
FRED_API_KEY=

# Optional overrides.
SMART_HEDGE_CONFIG=config.example.json
SMART_HEDGE_DB=.smart_hedge/decisions.sqlite3

# Optional: only needed for `smart-hedge guard-demo`, which exercises the
# full three-repository V2 architecture. Point at the sibling repositories'
# own compiled release binaries; see rust/README.md "Connecting the three
# repositories".
MARKET_INTELLIGENCE_MCP_BIN=
TRADE_GUARD_MCP_BIN=
